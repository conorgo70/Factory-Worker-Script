-- MOLTEN METAL POURING 
-- (This part of the script handles the extension of the liquid column cylinder and block1 and block2 which simulate the liquid accumulating in the mould.)
-- (It also handles the retraction of the cylinder when pouring is finished.)
task.delay(1.7, function()
	
		setBucketVisible(true)
		tiltBucket()

	task.wait(0.5)
		local block1 = workspace:WaitForChild("Block1")
		local block2 = workspace:WaitForChild("Block2")

		local growSpeed = 0.018
		local maxHeight = 0.34

		local startSize1 = block1.Size
		local startPos1 = block1.Position

		local startSize2 = block2.Size
		local startPos2 = block2.Position

		local currentHeight = startSize1.Y

		
		task.spawn(function()
			while currentHeight < maxHeight do
				local dt = task.wait()

				currentHeight += growSpeed * dt
				if currentHeight > maxHeight then
					currentHeight = maxHeight
				end

				block1.Size = Vector3.new(startSize1.X, currentHeight, startSize1.Z)
				block1.Position = startPos1 + Vector3.new(0, currentHeight/2, 0)

				block2.Size = Vector3.new(startSize2.X, currentHeight, startSize2.Z)
				block2.Position = startPos2 + Vector3.new(0, currentHeight/2, 0)
			end
		end)

		task.wait(0.8)
		
		if not fluidPart then
			warn("FluidCylinder missing!")
			return
		end

		fluidPart.Transparency = 0

		local growSpeed = 1
		local shrinkSpeed = 1
		local maxLength = 10
		local minLength = 0.1

		local startSize = fluidPart.Size
		local currentLength = startSize.X

		local axis = fluidPart.CFrame.RightVector

		local topPosition = fluidPart.Position + axis * (currentLength / 2)

		print("Starting cylinder growth")

		
		while currentLength < maxLength do
			local dt = task.wait()

			currentLength += growSpeed * dt
			if currentLength > maxLength then
				currentLength = maxLength
			end

			fluidPart.Size = Vector3.new(currentLength, startSize.Y, startSize.Z)

			local newCenter = topPosition - axis * (currentLength / 2)
			fluidPart.Position = newCenter
		end

		print("Liquid fully poured")
	
	task.spawn(function()

		task.wait(5)

		print("Starting cylinder shrink")

		local bottomPosition = fluidPart.Position - axis * (currentLength / 2)

		while currentLength > minLength do
			local dt = task.wait()

			currentLength -= shrinkSpeed * dt
			if currentLength < minLength then
				currentLength = minLength
			end

			fluidPart.Size = Vector3.new(currentLength, startSize.Y, startSize.Z)

			local newCenter = bottomPosition + axis * (currentLength / 2)
			fluidPart.Position = newCenter
		end

		fluidPart.Transparency = 1
	end)
	
	
		task.wait(30)

-- COOLING TRANSITION (This part of the script manages the cooling transition of block1 and block2, visually transitioning them from the red molten state to a cool, metallic gray.)

		local transitionTime = 30

		local startColor1 = block1.Color
		local startColor2 = block2.Color

		local elapsed = 0

		print("Starting cooling transition")

		while elapsed < transitionTime do
			local dt = task.wait()
			elapsed += dt

			local alpha = math.clamp(elapsed / transitionTime, 0, 1)

		block1.Color = startColor1:Lerp(Color3.new(0,0,0), alpha)
		block2.Color = startColor2:Lerp(Color3.new(0,0,0), alpha)
		end

		block1.Material = Enum.Material.Metal
		block2.Material = Enum.Material.Metal
	
	
