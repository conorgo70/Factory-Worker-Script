-- TILT (Controls the tilting of the bucket by modifying the Motor6D joint over time)
local function tiltBucket()
	local startC0 = motor.C0
	local endC0 = startC0 * CFrame.Angles(0, 0, math.rad(70))

	local startTime = tick()

	while tick() - startTime < 1 do
		local alpha = (tick() - startTime)
		motor.C0 = startC0:Lerp(endC0, alpha)
		task.wait()
	end

	motor.C0 = endC0
end


-- RETURN (Returns bucket to upright position)
local function resetBucketTilt()
	local startC0 = motor.C0

	local endC0 = startC0 * CFrame.Angles(0, 0, math.rad(-70))

	local duration = 1
	local startTime = tick()

	while tick() - startTime < duration do
		local alpha = (tick() - startTime) / duration
		motor.C0 = startC0:Lerp(endC0, alpha)
		task.wait()
	end

	motor.C0 = endC0
end

